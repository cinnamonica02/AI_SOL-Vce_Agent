# ─────────────────────────────────────────────────────────────────
#  VoiceDesk — Environment Variables Template
#
#  Copy this file to `.env` and fill in your secrets.
#  NEVER commit `.env` — it's gitignored.
#  When adding new variables, document them HERE first.
# ─────────────────────────────────────────────────────────────────


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  LLM / AI providers
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Anthropic Claude (used by ElevenLabs Conversational AI as LLM backend
# OR called directly from FastAPI bridge for fallback reasoning).
# Get key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxx

# OpenAI (alternative LLM, configurable in ElevenLabs agent settings).
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxx

# Google Gemini (alternative LLM option).
# Get key: https://ai.google.dev/
GOOGLE_API_KEY=

# Default model identifiers (used by bridge if it calls LLM directly).
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-4o


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  ElevenLabs (voice + Conversational AI)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# API key. REQUIRES paid plan (Creator $5/mo or Pro $22/mo) for
# Conversational AI access.
# Get key: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=sk_xxx

# Agent ID — created in the ElevenLabs Conversational AI UI.
# https://elevenlabs.io/app/conversational-ai
ELEVENLABS_AGENT_ID=

# Voice ID for the agent (Polish-friendly recommended).
# Browse voices: https://elevenlabs.io/app/voice-library
ELEVENLABS_VOICE_ID=

# Webhook secret for ElevenLabs tool calls (to verify incoming webhooks).
ELEVENLABS_WEBHOOK_SECRET=


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  Solana
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# RPC endpoint. Use Helius/QuickNode for production; public devnet for dev.
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_NETWORK=devnet

# Anchor program ID (filled in after first `anchor deploy`).
ANCHOR_PROGRAM_ID=

# Path to the wallet keypair used by the FastAPI bridge to submit txs
# (used for backend-side instructions; customer-side uses Phantom).
ANCHOR_WALLET=./keys/bridge-wallet.json

# USDC SPL Token mint
# Devnet USDC: 4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
# Mainnet USDC: EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  FastAPI bridge
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

API_HOST=0.0.0.0
API_PORT=8000
API_LOG_LEVEL=info

# Public URL of the bridge (used in ElevenLabs agent webhook config).
# Set this to your ngrok URL during dev, Railway URL in production.
PUBLIC_API_URL=https://your-ngrok-url.ngrok.io

# Public URL of the Next.js frontend. The bridge uses this to return
# customer deposit payment links after creating a booking intent.
FRONTEND_URL=http://localhost:3000


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  Frontend (Next.js — must be prefixed with NEXT_PUBLIC_)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_NETWORK=devnet
NEXT_PUBLIC_PROGRAM_ID=
NEXT_PUBLIC_USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
NEXT_PUBLIC_API_URL=http://localhost:8000

# ElevenLabs widget agent ID (public — safe to expose, scoped by domain).


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  Tooling
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ngrok auth token — for tunneling local FastAPI to ElevenLabs webhooks.
# Get token: https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  Phase 2+ (NOT in MVP — leave empty)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Twilio (Phase 2 — phone integration)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Privy (Phase 2 — embedded wallets for non-crypto users)
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=

# Mercuryo (Phase 2 — fiat onramp)
MERCURYO_API_KEY=
MERCURYO_WIDGET_ID=

# Supabase (Phase 2 — only if we add a separate database)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# KSeF (Phase 2 — Polish e-invoicing)
KSEF_API_URL=
KSEF_API_KEY=
