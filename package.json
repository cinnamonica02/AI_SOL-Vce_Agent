{
  "name": "voicedesk",
  "version": "0.1.0",
  "description": "VoiceDesk — voice-initiated lock-and-release deposit primitive on Solana",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "anchor build",
    "test": "anchor test",
    "test:devnet": "anchor test --skip-local-validator --provider.cluster devnet",
    "deploy:devnet": "anchor deploy --provider.cluster devnet",
    "deploy:devnet:ps": "powershell -ExecutionPolicy Bypass -File scripts/deploy-devnet.ps1",
    "deploy:devnet:bootstrap:ps": "powershell -ExecutionPolicy Bypass -File scripts/deploy-devnet.ps1 -CreateWallet",
    "verify:devnet:ps": "powershell -ExecutionPolicy Bypass -File scripts/verify-devnet-program.ps1",
    "sync:idl:ps": "powershell -ExecutionPolicy Bypass -File scripts/sync-idl.ps1",
    "lint": "prettier --check 'tests/**/*.ts'",
    "lint:fix": "prettier --write 'tests/**/*.ts'"
  },
  "devDependencies": {
    "@coral-xyz/anchor": "^0.31.1",
    "@solana/spl-token": "^0.4.6",
    "@solana/web3.js": "^1.95.2",
    "@types/bn.js": "^5.1.5",
    "@types/chai": "^4.3.16",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.12.0",
    "chai": "^4.5.0",
    "mocha": "^10.4.0",
    "prettier": "^3.3.0",
    "ts-mocha": "^10.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
