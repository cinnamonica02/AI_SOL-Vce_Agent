  "types": [
    {
      "name": "Booking",
      "docs": [
        "A Booking represents a single customer reservation against a Business.",
        "",
        "PDA seeds: [\"booking\", booking_id]",
        "`booking_id` is a 32-byte client-generated identifier (e.g. UUID v4 → bytes,",
        "or hash of business+customer+timestamp). It must be unique across the program."
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "booking_id",
            "docs": [
              "Unique booking identifier (32 bytes, generated by the bridge)"
            ],
            "type": {
              "array": [
                "u8",
                32
              ]
            }
          },
          {
            "name": "business",
            "docs": [
              "The Business PDA this booking belongs to"
            ],
            "type": "pubkey"
          },
          {
            "name": "customer",
            "docs": [
              "The customer's wallet (signs lock_deposit, customer_cancel)"
            ],
            "type": "pubkey"
          },
          {
            "name": "deposit_amount",
            "docs": [
              "Deposit amount in USDC base units (6 decimals)"
            ],
            "type": "u64"
          },
          {
            "name": "service_start",
            "docs": [
              "Service start (unix seconds)"
            ],
            "type": "i64"
          },
          {
            "name": "service_end",
            "docs": [
              "Service end (unix seconds)"
            ],
            "type": "i64"
          },
          {
            "name": "status",
            "docs": [
              "Current lifecycle state"
            ],
            "type": {
              "defined": {
                "name": "BookingStatus"
              }
            }
          },
          {
            "name": "created_at",
            "docs": [
              "When this booking record was created"
            ],
            "type": "i64"
          },
          {
            "name": "bump",
            "docs": [
              "PDA bump"
            ],
            "type": "u8"
          }
        ]
      }
    },
    {
      "name": "BookingStatus",
      "docs": [
        "Lifecycle of a single booking.",
        "",
        "State transitions:",
        "Pending           → Confirmed         (lock_deposit)",
        "Pending           → Expired           (timeout — Phase 2)",
        "Confirmed         → Released          (confirm_attendance)",
        "Confirmed         → PartiallyReleased (release_partial)",
        "Confirmed         → Claimed           (claim_full, after grace)",
        "Confirmed         → CustomerCancelled (customer_cancel, >cancellation_hours before)",
        "Confirmed         → LateCancelled     (customer_cancel, <cancellation_hours before)",
        "Confirmed         → Disputed          (raise_dispute — Phase 2)"
      ],
      "type": {
        "kind": "enum",
        "variants": [
          {
            "name": "Pending"
          },
          {
            "name": "Confirmed"
          },
          {
            "name": "Released"
          },
          {
            "name": "PartiallyReleased"
          },
          {
            "name": "Claimed"
          },
          {
            "name": "CustomerCancelled"
          },
          {
            "name": "LateCancelled"
          },
          {
            "name": "Disputed"
          }
        ]
      }
    },
    {
      "name": "Business",
      "docs": [
        "A Business represents an SMB onboarded onto VoiceDesk.",
        "",
        "PDA seeds: [\"business\", owner.key()]",
        "One business per wallet (MVP). Multi-business per wallet is Phase 2+."
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "owner",
            "docs": [
              "Wallet that controls this business (signs confirm_attendance, claim_full, etc.)"
            ],
            "type": "pubkey"
          },
          {
            "name": "vertical",
            "docs": [
              "Vertical category (informational; deposit logic is universal)"
            ],
            "type": {
              "defined": {
                "name": "Vertical"
              }
            }
          },
          {
            "name": "name",
            "docs": [
              "Display name (max 64 bytes)"
            ],
            "type": "string"
          },
          {
            "name": "default_deposit_amount",
            "docs": [
              "Default deposit amount in USDC base units (6 decimals).",
              "e.g. 50_000_000 = 50.00 USDC."
            ],
            "type": "u64"
          },
          {
            "name": "cancellation_hours",
            "docs": [
              "Hours before service start during which a customer can fully cancel.",
              "1..=720 (1 hour to 30 days)."
            ],
            "type": "u32"
          },
          {
            "name": "bump",
            "docs": [
              "PDA bump"
            ],
            "type": "u8"
          }
        ]
      }
    },
